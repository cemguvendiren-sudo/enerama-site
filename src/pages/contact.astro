---
import MainLayout from '../layouts/main.astro';

// Formspree endpoint — replace YOUR_FORMSPREE_ID with actual ID after signup.
// Until then, the form stays mailto fallback.
const formspreeEndpoint = 'https://formspree.io/f/YOUR_FORMSPREE_ID';
---

<MainLayout
  title="Contact Enerama | Engineering Team & Investor Relations"
  description="Get in touch with Enerama's engineering team. Technical consultation, investor inquiries, or general questions — we respond within 48 hours. Offices in USA, Switzerland, Türkiye, and Azerbaijan (representation)."
  keywords="contact enerama, engineering consultation, technical demo, investor relations, liquid desiccant inquiry"
  canonicalPath="/contact"
>
  <!-- Hero -->
  <section class="relative text-white py-20" style="background-color: #0B3D4C;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-2 rounded-full mb-6 text-sm font-medium" style="background-color: rgba(255,255,255,0.15);">
          48-Hour Response · Engineering Team
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          Let's Talk About Your Project
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 max-w-3xl">
          Whether you're planning a new facility, upgrading an existing system, or exploring investment opportunities — our engineering team responds within 48 hours.
        </p>
      </div>
    </div>
  </section>

  <!-- Inquiry Types -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold mb-4" style="color: #1B3A6B;">How Can We Help You?</h2>
        <p class="text-lg text-gray-600">Select the nature of your inquiry</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-lg border-2 border-gray-200 hover:border-[#0D7377] transition-colors">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Technical Project Inquiry</h3>
          <p class="text-gray-600 text-sm">New installation, retrofit, or upgrade. Talk to our engineering team.</p>
        </div>
        <div class="p-6 rounded-lg border-2 border-gray-200 hover:border-[#0D7377] transition-colors">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Investor Relations</h3>
          <p class="text-gray-600 text-sm">Investment opportunity, partnership, or financial information.</p>
        </div>
        <div class="p-6 rounded-lg border-2 border-gray-200 hover:border-[#0D7377] transition-colors">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">General Information</h3>
          <p class="text-gray-600 text-sm">Product questions, applications, or technical documentation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-20" style="background-color: #F9FAFB;">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">Send Us a Message</h2>
        <p class="text-gray-600">All fields marked * are required. We respond within 48 business hours.</p>
      </div>

      <form
        action={formspreeEndpoint}
        method="POST"
        class="bg-white p-8 rounded-lg shadow-sm space-y-6"
      >
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-2">First Name *</label>
            <input type="text" name="firstName" id="firstName" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent" />
          </div>
          <div>
            <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-2">Last Name *</label>
            <input type="text" name="lastName" id="lastName" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent" />
          </div>
          <div>
            <label for="company" class="block text-sm font-semibold text-gray-700 mb-2">Company *</label>
            <input type="text" name="company" id="company" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent" />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
            <input type="email" name="email" id="email" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent" />
          </div>
        </div>

        <div>
          <label for="industry" class="block text-sm font-semibold text-gray-700 mb-2">Industry / Application *</label>
          <select name="industry" id="industry" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent bg-white">
            <option value="">Select an industry...</option>
            <option>Agriculture & Greenhouses</option>
            <option>Vertical Farming</option>
            <option>Food Drying & Processing</option>
            <option>Food Storage</option>
            <option>Industrial Manufacturing</option>
            <option>Pharmaceuticals & Healthcare</option>
            <option>Data Centers</option>
            <option>Oil & Gas / Energy</option>
            <option>Marine</option>
            <option>Museums & Archives</option>
            <option>Investor / Financial</option>
            <option>Other</option>
          </select>
        </div>

        <div>
          <label for="projectType" class="block text-sm font-semibold text-gray-700 mb-2">Project Type *</label>
          <select name="projectType" id="projectType" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent bg-white">
            <option value="">Select a project type...</option>
            <option>New Installation</option>
            <option>Retrofit / Upgrade</option>
            <option>Facility Expansion</option>
            <option>System Replacement</option>
            <option>Investment Inquiry</option>
            <option>Technical Information Request</option>
            <option>Partnership Opportunity</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">Project Details *</label>
          <textarea name="message" id="message" rows="5" required class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-[#0D7377] focus:border-transparent" placeholder="Describe your facility, current climate challenges, and what you're trying to achieve..."></textarea>
        </div>

        <div class="flex items-start">
          <input type="checkbox" id="consent" name="consent" required class="mt-1 mr-3 h-4 w-4 rounded border-gray-300" />
          <label for="consent" class="text-sm text-gray-600">
            I agree to receive communications from Enerama Environmental Technologies regarding my inquiry. We respect your privacy and will never share your information.
          </label>
        </div>

        <button
          type="submit"
          class="w-full inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-sm hover:opacity-90 transition-opacity"
          style="background-color: #E07B39;"
        >
          Send Inquiry →
        </button>

        <p class="text-center text-xs text-gray-500">
          Prefer email? Write to <a href="mailto:info@enerama.com" class="underline hover:text-[#0D7377]">info@enerama.com</a>
        </p>
      </form>
    </div>
  </section>

  <!-- Offices -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">Our Offices</h2>
        <p class="text-xl text-gray-600">Four locations, one accountable team</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 rounded-lg border-2" style="border-color: #1B3A6B;">
          <div class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: #1B3A6B;">🇹🇷 Türkiye · Headquarters</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Istanbul</h3>
          <p class="text-sm text-gray-700 mb-3">Aydınlı mah. IAYOSB 10. sokak 3<br/>Tuzla, 34953 Istanbul</p>
          <a href="mailto:info@enerama.com" class="text-sm font-semibold hover:opacity-80" style="color: #E07B39;">info@enerama.com</a>
        </div>

        <div class="p-6 rounded-lg border-2" style="border-color: #E07B39;">
          <div class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: #E07B39;">🇺🇸 Americas</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">San Clemente, CA</h3>
          <p class="text-sm text-gray-700 mb-3">616 S El Camino Real, Ste A<br/>San Clemente, CA 92672, USA</p>
          <a href="mailto:info@enerama.com" class="text-sm font-semibold hover:opacity-80" style="color: #E07B39;">info@enerama.com</a>
        </div>

        <div class="p-6 rounded-lg border-2" style="border-color: #0D7377;">
          <div class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: #0D7377;">🇨🇭 Europe</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Zürich</h3>
          <p class="text-sm text-gray-700 mb-3">Zürich, Switzerland</p>
          <a href="mailto:info@enerama.com" class="text-sm font-semibold hover:opacity-80" style="color: #E07B39;">info@enerama.com</a>
        </div>

        <div class="p-6 rounded-lg border-2 bg-gray-50" style="border-color: #10B981;">
          <div class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: #10B981;">🇦🇿 Representation Office</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Baku, Azerbaijan</h3>
          <p class="text-sm text-gray-700 mb-3">Regional business development<br/>for the Caucasus</p>
          <a href="mailto:info@enerama.com" class="text-sm font-semibold hover:opacity-80" style="color: #E07B39;">info@enerama.com</a>
        </div>
      </div>

      <div class="mt-12 flex flex-wrap gap-x-8 gap-y-2 justify-center items-center text-sm text-gray-600">
        <span><strong class="text-gray-900">General:</strong> <a href="mailto:info@enerama.com" class="hover:text-[#0D7377]">info@enerama.com</a></span>
        <span><strong class="text-gray-900">Support:</strong> <a href="mailto:support@enerama.com" class="hover:text-[#0D7377]">support@enerama.com</a></span>
        <span><strong class="text-gray-900">LinkedIn:</strong> <a href="https://linkedin.com/company/enerama" target="_blank" rel="noopener noreferrer" class="hover:text-[#0D7377]">linkedin.com/company/enerama</a></span>
      </div>
    </div>
  </section>

  <!-- What Happens -->
  <section class="py-20" style="background-color: #F9FAFB;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          What Happens After You Contact Us
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {[
          { num: '1', time: 'Within 48 Hours', title: 'Initial Response', desc: 'A member of our engineering team reviews your inquiry and contacts you to confirm receipt and next steps.' },
          { num: '2', time: 'Day 2–3', title: 'Engineering Consultation', desc: 'We schedule a technical call to discuss your facility, requirements, constraints, and project objectives.' },
          { num: '3', time: 'Week 1–2', title: 'Site Assessment', desc: 'Our engineers evaluate your facility and develop a custom Dragon system configuration for your application.' },
          { num: '4', time: 'Week 2–3', title: 'Detailed Proposal', desc: 'You receive a complete proposal: system design, energy projections, water recovery estimates, and ROI analysis.' },
        ].map((item) => (
          <div class="bg-white p-6 rounded-lg shadow-sm">
            <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-white mb-4" style="background-color: #0D7377;">{item.num}</div>
            <div class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: #E07B39;">{item.time}</div>
            <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">{item.title}</h3>
            <p class="text-sm text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">Frequently Asked Questions</h2>
      </div>

      <div class="space-y-4">
        {[
          { q: 'What is the typical project timeline?', a: 'Timelines vary by scope. Small systems are operational in 4–6 weeks. Large industrial installations typically take 10–14 weeks from contract to commissioning. We provide a project-specific timeline in every proposal.' },
          { q: 'Do you work internationally?', a: 'Yes. Enerama has delivered 27 projects across 3 countries (USA, Switzerland, Türkiye) with a representation office in Baku, Azerbaijan. We design, manufacture, and commission systems globally. Our engineering team travels to your site for commissioning and training.' },
          { q: 'What information do you need for a preliminary assessment?', a: 'Basic facility details: square footage, outdoor climate conditions, indoor temperature and humidity requirements, existing HVAC equipment (if any), energy costs, and your application (agriculture, food processing, industrial, etc.). More detail helps, but we can start with general information.' },
          { q: 'Is Dragon suitable for retrofit into an existing facility?', a: 'Yes. Many Dragon installations are retrofits replacing underperforming HVAC systems. We integrate with existing infrastructure where possible to minimize disruption and cost. Our engineers assess your facility and recommend the optimal integration approach.' },
          { q: 'What kind of support do you provide after commissioning?', a: 'Every Enerama project includes 60-Day Online Support — our engineers remain actively engaged post-commissioning to optimize performance and train your staff. Remote monitoring via Mekasera SCADA is standard. Optional Maintenance Service Agreements (MSA) available for long-term support.' },
          { q: 'Can I visit an existing Dragon installation?', a: 'Subject to client confidentiality and availability, we arrange site visits for serious prospects. Contact us to discuss reference site visits in your region or industry. Detailed case studies and performance data are available under NDA for qualified investors and partners.' },
        ].map((item) => (
          <details class="group bg-gray-50 rounded-lg overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-gray-100">
              <span class="font-semibold" style="color: #1B3A6B;">{item.q}</span>
              <svg class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" style="color: #0D7377;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-gray-700 leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
