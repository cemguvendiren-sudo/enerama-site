---
import MainLayout from '../layouts/main.astro';

const steps = [
  {
    num: '1',
    title: 'Engineering & Assessment',
    description: 'We begin with a thorough assessment of your facility, outdoor climate, process loads, and operational constraints. Our engineering team designs a custom Dragon configuration for your environment.',
    items: [
      'Site evaluation and feasibility study',
      'Energy consumption baseline analysis',
      'Process load characterization',
      'Custom Dragon system design',
      'ROI modeling and payback projections',
    ],
  },
  {
    num: '2',
    title: 'Procurement & Manufacturing',
    description: 'All critical Dragon components are manufactured in our Istanbul facility. Supporting equipment procured from qualified suppliers. Full supply-chain ownership means no finger-pointing when issues arise.',
    items: [
      'Component selection and qualification',
      'In-house Dragon manufacturing (Istanbul)',
      'Supply chain management for auxiliary systems',
      'Factory acceptance testing',
      'Coordinated shipping and logistics',
    ],
  },
  {
    num: '3',
    title: 'Construction & Commissioning',
    description: 'Our engineering team travels to your site for installation, integration with existing infrastructure, and full system commissioning. We do not hand off to subcontractors — the same team that designed your system also commissions it.',
    items: [
      'On-site installation by Enerama engineers',
      'Integration with existing building infrastructure',
      'Quality control and performance verification',
      'System commissioning against design spec',
      'Operator training and handover documentation',
    ],
  },
  {
    num: '4',
    title: '60-Day Online Support + Optional MSA',
    description: 'Every project includes 60 days of active online support post-commissioning. Our engineers monitor performance via Mekasera SCADA, tune operational parameters, and respond to operator questions. Optional Maintenance Service Agreement available for long-term support.',
    items: [
      'Active remote monitoring via Mekasera SCADA',
      'Operational parameter optimization',
      'Performance validation against design KPIs',
      'Operator Q&A and training reinforcement',
      'Optional MSA for ongoing maintenance and upgrades',
    ],
  },
];
---

<MainLayout
  title="How We Work | Full EPC Delivery by Enerama"
  description="Full EPC (Engineering, Procurement, Construction) delivery model. Single-point accountability from design to 60-day post-commissioning support. Not just a vendor — a long-term partner."
  keywords="EPC delivery, engineering procurement construction, dragon commissioning, industrial HVAC installation, 60-day support"
  canonicalPath="/how-we-work"
>
  <!-- Hero -->
  <section class="relative text-white py-20" style="background-color: #0B3D4C;">
    <div class="absolute inset-0 opacity-30" style="background-image: url('https://cdn.prod.website-files.com/69c9538c5e6a6b66c71a24ee/69d11780cc6cf2cf78c74d7b_IMG-20201203-WA0000.jpg'); background-size: cover; background-position: center;"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-2 rounded-full mb-6 text-sm font-medium" style="background-color: rgba(255,255,255,0.15);">
          Full EPC Delivery · Single Point of Accountability
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          How We Work
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 max-w-3xl">
          Other companies sell you equipment and leave. Enerama owns the outcome — from the first site visit to commissioning and beyond.
        </p>
      </div>
    </div>
  </section>

  <!-- Why EPC Matters -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6" style="color: #1B3A6B;">
          Why Full EPC Matters
        </h2>
        <p class="text-lg text-gray-700 leading-relaxed">
          When engineering, procurement, and construction are split between vendors, performance problems become finger-pointing exercises. Enerama owns all three — which means when a system underperforms, there is one team to call, and one team responsible. This is why our Dragon platform is field-proven across 27 projects and 14 years.
        </p>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="py-20" style="background-color: #F9FAFB;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">Our Process</h2>
        <p class="text-xl text-gray-600">Four phases. One accountable team.</p>
      </div>

      <div class="max-w-5xl mx-auto space-y-8">
        {steps.map((step) => (
          <div class="bg-white rounded-lg shadow-sm p-8 border-l-4" style="border-color: #E07B39;">
            <div class="flex flex-col md:flex-row md:items-start gap-6">
              <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #1B3A6B;">
                {step.num}
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold mb-3" style="color: #1B3A6B;">{step.title}</h3>
                <p class="text-gray-700 leading-relaxed mb-5">{step.description}</p>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-2">
                  {step.items.map((item) => (
                    <li class="flex items-start text-sm text-gray-700">
                      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" style="color: #0D7377;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="ml-2">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          Typical Project Timeline
        </h2>
        <p class="text-xl text-gray-600">From first contact to fully operational system</p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div class="text-center p-6 rounded-lg border-2" style="border-color: #0D7377;">
            <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #0D7377;">Week 1–3</div>
            <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">Design & Proposal</div>
            <p class="text-gray-600 text-sm">Site assessment, engineering, formal proposal</p>
          </div>
          <div class="text-center p-6 rounded-lg border-2" style="border-color: #0D7377;">
            <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #0D7377;">Week 4–10</div>
            <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">Manufacturing</div>
            <p class="text-gray-600 text-sm">Dragon manufacturing, component procurement, FAT</p>
          </div>
          <div class="text-center p-6 rounded-lg border-2" style="border-color: #0D7377;">
            <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #0D7377;">Week 10–14</div>
            <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">Installation</div>
            <p class="text-gray-600 text-sm">On-site construction, integration, commissioning</p>
          </div>
          <div class="text-center p-6 rounded-lg border-2" style="border-color: #E07B39;">
            <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #E07B39;">Post‑Commissioning</div>
            <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">60‑Day Support</div>
            <p class="text-gray-600 text-sm">Active monitoring, tuning, training</p>
          </div>
        </div>
        <p class="text-center text-sm text-gray-600 mt-6">
          Timeline varies by scope: small systems 4–6 weeks · industrial installations 10–14 weeks · complex multi-site projects longer.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20" style="background-color: #1B3A6B;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
        Ready to Get Started?
      </h2>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Share your facility details and we will respond within 48 hours with a preliminary assessment.
      </p>
      <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity" style="background-color: #E07B39;">
        Start Your Project
      </a>
    </div>
  </section>
</MainLayout>
