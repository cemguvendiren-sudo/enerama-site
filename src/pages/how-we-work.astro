---
import MainLayout from '../layouts/main.astro';
---

<MainLayout
  title="How We Work | Full EPC Delivery | Enerama Environmental Technologies"
  description="Full EPC (Engineering, Procurement, Construction) delivery model. Single-point accountability from design to 60-day post-commissioning support. Not just a vendor — a long-term partner."
  keywords="EPC delivery, engineering procurement construction, dragon commissioning, industrial HVAC installation, 60-day support"
  canonicalPath="/how-we-work"
>
  <!-- Hero -->
  <section class="relative text-white py-20" style="background-color: #0B3D4C;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-block px-4 py-2 rounded-full mb-6 text-sm font-medium" style="background-color: rgba(255,255,255,0.15);">
          Full EPC Delivery · End-to-End Accountability
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          We Own the Outcome. Not Just the Equipment.
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 mb-8 max-w-3xl leading-relaxed">
          Most HVAC companies deliver products and leave. Enerama designs, engineers, builds, and commissions your complete climate environment — then stays engaged until your team is fully confident.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity"
          style="background-color: #E07B39;"
        >
          Start Your Project
        </a>
      </div>
    </div>
  </section>

  <!-- What Does Full EPC Mean? -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          What Does Full EPC Mean?
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Engineering · Procurement · Construction — one team, one contract, one point of accountability
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gray-50 p-8 rounded-lg border-t-4" style="border-color: #1B3A6B;">
          <h3 class="text-2xl font-bold mb-4" style="color: #1B3A6B;">E — Engineering</h3>
          <p class="text-gray-700 leading-relaxed">
            We analyze your facility, define the precise climate requirements, and design a custom Dragon Liquid Desiccant system tailored to your specific environment, capacity, and energy targets.
          </p>
        </div>
        <div class="bg-gray-50 p-8 rounded-lg border-t-4" style="border-color: #0D7377;">
          <h3 class="text-2xl font-bold mb-4" style="color: #0D7377;">P — Procurement</h3>
          <p class="text-gray-700 leading-relaxed">
            We source, specify, and produce every component — from the Dragon platform hardware to auxiliary systems. No third-party coordination burden for you.
          </p>
        </div>
        <div class="bg-gray-50 p-8 rounded-lg border-t-4" style="border-color: #E07B39;">
          <h3 class="text-2xl font-bold mb-4" style="color: #E07B39;">C — Construction</h3>
          <p class="text-gray-700 leading-relaxed">
            Our engineering team installs, integrates, tests, and commissions the complete system on-site. We don't leave until it works exactly as designed.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Your Project, Step by Step -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          Your Project, Step by Step
        </h2>
        <p class="text-xl text-gray-600">
          A transparent process — from first call to fully operational system
        </p>
      </div>

      <div class="max-w-4xl mx-auto space-y-6">
        <!-- Step 1 -->
        <div class="bg-white p-8 rounded-lg shadow-md flex gap-6 items-start">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #0D7377;">1</div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #1B3A6B;">Initial Consultation</h3>
            <p class="text-gray-700 leading-relaxed">
              We start by understanding your facility, your environment, and your goals. No pressure, no sales pitch — just an engineering conversation about what you need.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="bg-white p-8 rounded-lg shadow-md flex gap-6 items-start">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #0D7377;">2</div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #1B3A6B;">Facility Assessment & Feasibility</h3>
            <p class="text-gray-700 leading-relaxed">
              Our engineers assess your site conditions — dimensions, climate zone, existing systems, energy consumption — and determine the optimal Dragon configuration for your application.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="bg-white p-8 rounded-lg shadow-md flex gap-6 items-start">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #0D7377;">3</div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #1B3A6B;">Custom System Design</h3>
            <p class="text-gray-700 leading-relaxed">
              We engineer a complete solution: airflow modeling, Liquid Desiccant concentration parameters, regeneration heat source selection, water recovery integration, and control logic.
            </p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="bg-white p-8 rounded-lg shadow-md flex gap-6 items-start">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #0D7377;">4</div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #1B3A6B;">Procurement & Manufacturing</h3>
            <p class="text-gray-700 leading-relaxed">
              We produce and prepare all system components. Dragon platform units are configured and tested at our facility before shipment to your site.
            </p>
          </div>
        </div>

        <!-- Step 5 -->
        <div class="bg-white p-8 rounded-lg shadow-md flex gap-6 items-start">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #0D7377;">5</div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #1B3A6B;">On-Site Installation & Commissioning</h3>
            <p class="text-gray-700 leading-relaxed">
              Our team installs and integrates the complete system. We run full performance tests, validate all parameters, and ensure the system meets every specification before handover.
            </p>
          </div>
        </div>

        <!-- Step 6 -->
        <div class="bg-white p-8 rounded-lg shadow-md flex gap-6 items-start border-l-4" style="border-color: #E07B39;">
          <div class="flex-shrink-0 w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color: #E07B39;">6</div>
          <div>
            <h3 class="text-xl font-bold mb-2" style="color: #E07B39;">60‑Day Online Support</h3>
            <p class="text-gray-700 leading-relaxed">
              After commissioning, we stay engaged for 60 days via online monitoring and support. We train your team, track system performance, and resolve any fine-tuning needed for optimal operation.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Problem With Conventional HVAC Delivery -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-center" style="color: #1B3A6B;">
          The Problem With Conventional HVAC Delivery
        </h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-4">
          Most climate control projects involve multiple vendors — a manufacturer, a local installer, a controls company, a commissioning specialist. When something goes wrong, each points to the other. You're left managing conflicts between parties who share no accountability.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed font-semibold">
          Enerama eliminates this. One contract. One team. One point of contact from day one to full operation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Conventional Multi-Vendor -->
        <div class="bg-gray-100 p-8 rounded-lg border-2 border-gray-300">
          <h3 class="text-xl font-bold mb-4 text-gray-700">Conventional Multi-Vendor</h3>
          <ul class="space-y-3">
            <li class="flex gap-3 text-gray-700">
              <span class="text-red-500 flex-shrink-0">✗</span>
              <span>Multiple contracts</span>
            </li>
            <li class="flex gap-3 text-gray-700">
              <span class="text-red-500 flex-shrink-0">✗</span>
              <span>Blame-shifting between parties</span>
            </li>
            <li class="flex gap-3 text-gray-700">
              <span class="text-red-500 flex-shrink-0">✗</span>
              <span>No single accountability</span>
            </li>
            <li class="flex gap-3 text-gray-700">
              <span class="text-red-500 flex-shrink-0">✗</span>
              <span>You manage coordination</span>
            </li>
            <li class="flex gap-3 text-gray-700">
              <span class="text-red-500 flex-shrink-0">✗</span>
              <span>Support ends at installation</span>
            </li>
          </ul>
        </div>

        <!-- Enerama Full EPC -->
        <div class="p-8 rounded-lg border-2" style="background-color: #f0fdfa; border-color: #0D7377;">
          <h3 class="text-xl font-bold mb-4" style="color: #0D7377;">Enerama Full EPC</h3>
          <ul class="space-y-3">
            <li class="flex gap-3 text-gray-800">
              <span class="flex-shrink-0" style="color: #0D7377;">✓</span>
              <span>Single contract</span>
            </li>
            <li class="flex gap-3 text-gray-800">
              <span class="flex-shrink-0" style="color: #0D7377;">✓</span>
              <span>One team owns all outcomes</span>
            </li>
            <li class="flex gap-3 text-gray-800">
              <span class="flex-shrink-0" style="color: #0D7377;">✓</span>
              <span>Full accountability end-to-end</span>
            </li>
            <li class="flex gap-3 text-gray-800">
              <span class="flex-shrink-0" style="color: #0D7377;">✓</span>
              <span>We manage everything</span>
            </li>
            <li class="flex gap-3 text-gray-800">
              <span class="flex-shrink-0" style="color: #0D7377;">✓</span>
              <span>60-day post-commissioning support</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Typical Project Timeline -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          Typical Project Timeline
        </h2>
        <p class="text-xl text-gray-600">
          From signed contract to fully operational system
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-6xl mx-auto">
        <div class="text-center p-6 rounded-lg border-2 bg-white" style="border-color: #1B3A6B;">
          <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #1B3A6B;">Weeks 1–2</div>
          <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">Engineering & Design</div>
          <p class="text-gray-600 text-sm">Site assessment, system architecture, custom configuration</p>
        </div>
        <div class="text-center p-6 rounded-lg border-2 bg-white" style="border-color: #0D7377;">
          <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #0D7377;">Weeks 3–6</div>
          <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">Production & Prep</div>
          <p class="text-gray-600 text-sm">Dragon manufacturing, component procurement, FAT</p>
        </div>
        <div class="text-center p-6 rounded-lg border-2 bg-white" style="border-color: #0D7377;">
          <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #0D7377;">Weeks 7–10</div>
          <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">Installation & Commissioning</div>
          <p class="text-gray-600 text-sm">On-site construction, integration, commissioning</p>
        </div>
        <div class="text-center p-6 rounded-lg border-2 bg-white" style="border-color: #E07B39;">
          <div class="text-sm font-semibold uppercase tracking-wider mb-2" style="color: #E07B39;">Weeks 11–14</div>
          <div class="text-lg font-bold mb-2" style="color: #1B3A6B;">60‑Day Support Period</div>
          <p class="text-gray-600 text-sm">Active monitoring, tuning, training</p>
        </div>
      </div>

      <p class="text-center text-sm text-gray-600 mt-8 max-w-3xl mx-auto">
        Note: Timeline varies by project scope and site conditions. Complex multi-unit installations may require additional time. Contact us for a project-specific estimate.
      </p>
    </div>
  </section>

  <!-- This Process Has Been Proven 27 Times -->
  <section class="py-20" style="background-color: #1B3A6B;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">
          This Process Has Been Proven 27 Times
        </h2>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto">
          Across agriculture, food processing, industrial, and controlled environment applications.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto mb-12">
        <div class="text-center">
          <div class="text-5xl font-bold mb-2 text-white">27</div>
          <div class="text-base text-gray-300">Projects Completed</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold mb-2 text-white">14 Years</div>
          <div class="text-base text-gray-300">Average System Uptime</div>
        </div>
        <div class="text-center">
          <div class="text-5xl font-bold mb-2 text-white">3</div>
          <div class="text-base text-gray-300">Countries Served</div>
        </div>
      </div>

      <div class="text-center">
        <a
          href="/case-studies"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity"
          style="background-color: #E07B39;"
        >
          See Our Projects
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6" style="color: #1B3A6B;">
        Ready to Start Your Project?
      </h2>
      <p class="text-xl text-gray-600 mb-8 leading-relaxed">
        Tell us about your facility and requirements. Our engineering team will respond within 48 hours.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity"
          style="background-color: #E07B39;"
        >
          Contact Our Engineering Team
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg border-2 transition-colors"
          style="border-color: #1B3A6B; color: #1B3A6B;"
        >
          Download Technical Brief
        </a>
      </div>
    </div>
  </section>
</MainLayout>
