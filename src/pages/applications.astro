---
import MainLayout from '../layouts/main.astro';

const applications = [
  {
    category: 'Agriculture',
    title: 'Greenhouse & Controlled Agriculture',
    problem: 'Fungal disease, inconsistent yields, high HVAC energy cost',
    advantages: [
      'Independent humidity control eliminates fungal risk',
      'Natural Liquid Desiccant pathogen elimination — no fungicides',
      '30–70% lower energy vs refrigerant-based systems',
      'Water recovered from air reused for irrigation',
      'Year-round production regardless of outdoor climate',
    ],
  },
  {
    category: 'Vertical Farming',
    title: 'Indoor Vertical Farming & HP Aeroponics',
    problem: 'VPD control, high lighting heat load, moisture management',
    advantages: [
      'Precise VPD management for maximum plant growth rate',
      'Independent temperature and humidity control',
      'Natural pathogen suppression — critical in dense vertical environments',
      'CO₂ enrichment integration compatible',
      'Water recovery reduces operational cost',
    ],
  },
  {
    category: 'Food Processing',
    title: 'Food Drying & Processing',
    problem: 'Energy-intensive drying, mold risk, product quality consistency',
    advantages: [
      'Precise dew point control for uniform drying',
      'Natural mold and bacteria elimination on contact',
      '30–70% energy reduction vs conventional drying',
      'Continuous 24/7 operation at industrial scale',
      'Water recovery as byproduct of drying process',
    ],
  },
  {
    category: 'Food Storage',
    title: 'Cold Storage & Warehouse',
    problem: 'Humidity fluctuation, mold, energy cost',
    advantages: [
      'Stable humidity prevents product degradation',
      'Natural pathogen elimination — no chemical fogging',
      'Lower energy than refrigeration-based humidity control',
      'Compatible with existing cold storage infrastructure',
    ],
  },
  {
    category: 'Industrial',
    title: 'Industrial Manufacturing',
    problem: 'Corrosion, dimensional tolerances, worker comfort, high HVAC cost',
    advantages: [
      'Independent humidity control prevents corrosion',
      'Precise environmental conditions for sensitive manufacturing processes',
      'Significant energy savings at industrial scale',
      'Compatible with waste heat recovery',
    ],
  },
  {
    category: 'Pharmaceutical',
    title: 'Pharmaceuticals & Healthcare',
    problem: 'Regulatory compliance, sterile environment, pathogen control',
    advantages: [
      'Natural pathogen elimination — bacteria, mold, viruses destroyed on Liquid Desiccant contact',
      'Precise humidity for GMP compliance',
      'No chemical additives required',
      'Continuous monitoring via Mekasera SCADA',
    ],
  },
  {
    category: 'Data Centers',
    title: 'Data Centers & Technology',
    problem: 'Heat management, humidity control, energy cost, uptime requirements',
    advantages: [
      'Independent temperature and humidity control',
      'Lower PUE (Power Usage Effectiveness)',
      '24/7 reliability proven over 14 years',
    ],
  },
  {
    category: 'Energy',
    title: 'Oil, Gas & Energy Sector',
    problem: 'Corrosion in humid environments, remote locations, harsh conditions',
    advantages: [
      'Humidity control prevents corrosion in pipelines and equipment',
      'Mobile Hybrid Energy Station for remote/off-grid deployment',
      'Containerized solutions for field operations',
      'Operates in extreme climates',
    ],
  },
  {
    category: 'Marine',
    title: 'Marine & Cruise',
    problem: 'High humidity, salt air corrosion, passenger comfort, energy efficiency',
    advantages: [
      'Superior dehumidification in high-humidity marine environments',
      'Natural pathogen suppression for passenger health',
      'Energy savings vs marine HVAC systems',
      'Compact, robust design for marine installation',
    ],
  },
  {
    category: 'Archive',
    title: 'Museums, Archives & Libraries',
    problem: 'Preservation humidity, mold risk, chemical-free requirement',
    advantages: [
      'Precise long-term humidity stability',
      'Natural pathogen elimination — no chemical fumigation required',
      'Low energy operation for 24/7 preservation',
      'Silent, reliable, minimal maintenance',
    ],
  },
];
---

<MainLayout
  title="Applications | Industrial Climate Control Across 10+ Industries"
  description="Liquid desiccant climate solutions for greenhouses, food processing, data centers, pharmaceuticals, manufacturing, and more. Proven in demanding humidity-critical environments since 2011."
  keywords="greenhouse climate control, food drying, data center cooling, pharmaceutical HVAC, industrial dehumidification, controlled environment agriculture, manufacturing climate control"
  canonicalPath="/applications"
>
  <!-- Hero -->
  <section class="relative text-white py-20" style="background-color: #0B3D4C;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <div class="inline-block px-4 py-2 rounded-full mb-6 text-sm font-medium" style="background-color: rgba(255,255,255,0.15);">
          10+ Sectors · 3 Countries · 27 Projects
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          Precision Climate Control for Demanding Environments
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 max-w-3xl mx-auto">
          Dragon™ Liquid Desiccant technology performs where conventional HVAC fails — high humidity loads, pathogen-sensitive environments, energy-constrained operations, and water-stressed regions.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="py-10" style="background-color: #1B3A6B;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white">10+</div>
          <div class="text-sm text-gray-300 mt-1">Industry Sectors</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white">27</div>
          <div class="text-sm text-gray-300 mt-1">Projects Delivered</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold text-white">3</div>
          <div class="text-sm text-gray-300 mt-1">Countries (USA · CH · TR)</div>
        </div>
        <div>
          <div class="text-3xl md:text-4xl font-bold" style="color: #E07B39;">30–70%</div>
          <div class="text-sm text-gray-300 mt-1">Energy Savings vs Conventional</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Applications Grid -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          Where Dragon™ Performs
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Each application leverages a different combination of Dragon's core capabilities
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {applications.map((app) => (
          <article class="p-6 rounded-lg border-2 border-gray-200 hover:border-[#0D7377] hover:shadow-md transition-all">
            <div class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: #E07B39;">{app.category}</div>
            <h3 class="text-xl font-bold mb-4" style="color: #1B3A6B;">{app.title}</h3>

            <div class="mb-4">
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-1">The problem:</div>
              <p class="text-gray-700">{app.problem}</p>
            </div>

            <div>
              <div class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">Dragon advantage:</div>
              <ul class="space-y-1.5">
                {app.advantages.map((adv) => (
                  <li class="flex items-start text-sm text-gray-700">
                    <span class="flex-shrink-0 w-1.5 h-1.5 rounded-full mt-2 mr-3" style="background-color: #0D7377;"></span>
                    <span>{adv}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Universal Capabilities -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          Capabilities That Work Across Every Sector
        </h2>
        <p class="text-xl text-gray-600">Dragon's core advantages apply regardless of your industry</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Natural Pathogen Elimination</h3>
          <p class="text-gray-600 text-sm">
            Liquid desiccant naturally destroys airborne bacteria, mold spores, and viruses on contact — no sector is immune to biological contamination.
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Water Recovery</h3>
          <p class="text-gray-600 text-sm">
            Every Dragon installation recovers water as a byproduct — reducing operational costs and conserving resources in water-stressed regions.
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Energy Independence</h3>
          <p class="text-gray-600 text-sm">
            30–70% less energy than conventional HVAC. Solar TES module (pre-commercial) targets fully renewable operation — critical for ESG compliance.
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Independent Control</h3>
          <p class="text-gray-600 text-sm">
            Temperature and humidity controlled independently — a capability no refrigerant system can match.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6" style="color: #1B3A6B;">
        Your Industry. Your Environment. Your Solution.
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Tell us about your application — our engineers will design the right Dragon configuration.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity" style="background-color: #E07B39;">
          Discuss Your Application
        </a>
        <a href="/case-studies" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg border-2 hover:opacity-90 transition-opacity" style="border-color: #1B3A6B; color: #1B3A6B;">
          See Our Projects
        </a>
      </div>
    </div>
  </section>
</MainLayout>
