---
import MainLayout from '../layouts/main.astro';
---

<MainLayout
  title="Investor Relations | Enerama Environmental Technologies"
  description="Investment opportunity in PCT patented Liquid Desiccant climate technology. 27 commissioned projects, 14 years field-proven, $370B HVAC market facing mandatory transition. Dragon Solar TES PCT filed Q1 2026."
  keywords="enerama investment, cleantech investment, liquid desiccant patent, HVAC market, industrial water, solar thermal storage, ESG investment"
  canonicalPath="/investors"
>
  <!-- Hero -->
  <section class="relative text-white py-20" style="background-color: #0B3D4C;">
    <div class="absolute inset-0 opacity-20" style="background-image: url('https://cdn.prod.website-files.com/69c9538c5e6a6b66c71a24ee/69d11782b05a7f49fdd94aa1_IMG-20201202-WA0001.jpg'); background-size: cover; background-position: center;"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <div class="inline-block px-4 py-2 rounded-full mb-6 text-sm font-medium" style="background-color: rgba(224, 123, 57, 0.2); color: #E07B39;">
          Investment Opportunity · Deep Tech · CleanTech
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6 text-balance">
          One Platform. Three Global Problems Solved.
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 max-w-3xl mb-8">
          Enerama's patented Liquid Desiccant technology simultaneously addresses energy efficiency, water scarcity, and refrigerant regulation — in a single field-proven system.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity" style="background-color: #E07B39;">
            Schedule a Meeting
          </a>
          <a href="mailto:info@enerama.com" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg border-2 border-white text-white hover:bg-white hover:text-[#0B3D4C] transition-colors">
            Request Investor Brief
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Market Opportunity -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-block px-4 py-2 rounded-full mb-4 text-sm font-semibold tracking-wide" style="background-color: rgba(224, 123, 57, 0.1); color: #E07B39;">
          MARKET OPPORTUNITY
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          A $370B Market Facing Mandatory Disruption
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="p-6 rounded-lg border-2" style="border-color: #0D7377;">
          <div class="text-4xl font-bold mb-2" style="color: #E07B39;">$370B</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Global HVAC Market by 2030</h3>
          <p class="text-gray-600 text-sm">CAGR 6.1%</p>
        </div>
        <div class="p-6 rounded-lg border-2" style="border-color: #0D7377;">
          <div class="text-4xl font-bold mb-2" style="color: #E07B39;">2030</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">EU & US Refrigerant Phase-Out</h3>
          <p class="text-gray-600 text-sm">Mandatory transition</p>
        </div>
        <div class="p-6 rounded-lg border-2" style="border-color: #0D7377;">
          <div class="text-4xl font-bold mb-2" style="color: #E07B39;">$180B</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Industrial Water Treatment Market</h3>
          <p class="text-gray-600 text-sm">Growing 7% annually</p>
        </div>
        <div class="p-6 rounded-lg border-2" style="border-color: #0D7377;">
          <div class="text-4xl font-bold mb-2" style="color: #E07B39;">30–70%</div>
          <h3 class="text-lg font-bold mb-2" style="color: #1B3A6B;">Energy Reduction with Dragon</h3>
          <p class="text-gray-600 text-sm">Validated across 27 projects</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Defensibility -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          Why Enerama's Position Is Defensible
        </h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Three barriers competitors cannot easily replicate
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 rounded-lg flex items-center justify-center mb-6" style="background-color: rgba(224, 123, 57, 0.1);">
            <svg class="w-7 h-7" style="color: #E07B39;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: #1B3A6B;">PCT Patent Protection</h3>
          <p class="text-gray-600 leading-relaxed">
            PCT patent filed Q1 2026 covering the Dragon Solar TES integration. Liquid Desiccant platform trade secrets accumulated over 14 years of continuous field operation.
          </p>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 rounded-lg flex items-center justify-center mb-6" style="background-color: rgba(13, 115, 119, 0.1);">
            <svg class="w-7 h-7" style="color: #0D7377;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: #1B3A6B;">14 Years of Operational Data</h3>
          <p class="text-gray-600 leading-relaxed">
            350+ installed systems across 3 countries. This dataset cannot be replicated without years of real-world deployment.
          </p>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 rounded-lg flex items-center justify-center mb-6" style="background-color: rgba(27, 58, 107, 0.1);">
            <svg class="w-7 h-7" style="color: #1B3A6B;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3" style="color: #1B3A6B;">Full EPC Delivery Model</h3>
          <p class="text-gray-600 leading-relaxed">
            Enerama designs, engineers, procures, constructs, and commissions. Clients receive a working environment — not a product to install. This creates deep customer relationships and high switching costs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Traction -->
  <section class="py-20" style="background-color: #1B3A6B;">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">
          Proven at Scale
        </h2>
        <p class="text-xl text-gray-300">Not a prototype. A validated platform.</p>
      </div>

      <div class="max-w-3xl mx-auto space-y-4 mb-8">
        {[
          '350+ conditioning systems installed',
          '2,830 kW total installed power across active projects',
          '27 commissioned projects — USA, Switzerland, Türkiye',
          '14+ years of continuous operation across active installations',
          'PCT patent filed Q1 2026 — Solar TES module in pre-commercial development',
        ].map((item) => (
          <div class="flex items-start bg-white/10 backdrop-blur-sm p-4 rounded-lg border border-white/20">
            <svg class="w-6 h-6 flex-shrink-0 mt-0.5" style="color: #E07B39;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="ml-3 text-white text-lg">{item}</span>
          </div>
        ))}
      </div>

      <div class="max-w-3xl mx-auto">
        <blockquote class="p-6 rounded-lg border-l-4 text-gray-200 italic bg-white/5" style="border-color: #E07B39;">
          Blue Frontier, our closest US competitor, raised $20M from Bill Gates' Breakthrough Energy — but remains pre-commercial. Enerama has 14 years of real-world results they do not.
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Revenue Model -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">
          How Enerama Generates Revenue
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-8 rounded-lg border-2 border-gray-200">
          <h3 class="text-xl font-bold mb-3" style="color: #1B3A6B;">EPC Project Delivery</h3>
          <p class="text-gray-600 leading-relaxed">
            Full engineering, procurement, and construction contracts for climate control systems. High-value, long-term engagements with industrial and agricultural clients.
          </p>
        </div>
        <div class="p-8 rounded-lg border-2 border-gray-200">
          <h3 class="text-xl font-bold mb-3" style="color: #1B3A6B;">Service & Maintenance</h3>
          <p class="text-gray-600 leading-relaxed">
            Long-term service agreements following system commissioning. Recurring revenue with low churn — clients depend on system continuity for daily operations.
          </p>
        </div>
        <div class="p-8 rounded-lg border-2 border-gray-200">
          <h3 class="text-xl font-bold mb-3" style="color: #1B3A6B;">Technology Licensing (Future)</h3>
          <p class="text-gray-600 leading-relaxed">
            Dragon Solar TES module positions Enerama for future licensing to regional HVAC manufacturers and EPC contractors globally once commercialized.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Use of Investment -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: #1B3A6B;">Use of Investment</h2>
        <p class="text-xl text-gray-600">Capital will accelerate three priorities</p>
      </div>

      <div class="max-w-4xl mx-auto space-y-4">
        <div class="bg-white p-6 rounded-lg shadow-sm flex items-center gap-6">
          <div class="text-4xl font-bold flex-shrink-0 w-24" style="color: #E07B39;">45%</div>
          <div class="flex-1">
            <h3 class="text-lg font-bold mb-1" style="color: #1B3A6B;">Dragon Solar TES Commercialization</h3>
            <p class="text-gray-600 text-sm">First field deployment, performance validation, manufacturing scale-up</p>
          </div>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm flex items-center gap-6">
          <div class="text-4xl font-bold flex-shrink-0 w-24" style="color: #0D7377;">35%</div>
          <div class="flex-1">
            <h3 class="text-lg font-bold mb-1" style="color: #1B3A6B;">Market Expansion — USA & Europe</h3>
            <p class="text-gray-600 text-sm">Sales team, partnerships, project pipeline development in target markets</p>
          </div>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm flex items-center gap-6">
          <div class="text-4xl font-bold flex-shrink-0 w-24" style="color: #1B3A6B;">20%</div>
          <div class="flex-1">
            <h3 class="text-lg font-bold mb-1" style="color: #1B3A6B;">Technology & Patent Portfolio</h3>
            <p class="text-gray-600 text-sm">Additional patent filings, R&D, technical documentation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6" style="color: #1B3A6B;">
        Ready to Learn More?
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        We welcome conversations with strategic investors, family offices, and industry partners.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white rounded-lg shadow-lg hover:opacity-90 transition-opacity" style="background-color: #E07B39;">
          Schedule a 30-Min Call
        </a>
        <a href="mailto:info@enerama.com" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded-lg border-2 hover:opacity-90 transition-opacity" style="border-color: #1B3A6B; color: #1B3A6B;">
          info@enerama.com
        </a>
      </div>
    </div>
  </section>
</MainLayout>
